<Window x:Class="OBS_StreamMusicViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OBS Stream Music Viewer" Height="254" Width="420"
        Background="#18181A" WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True"
        Icon="OSMV_logo.ico"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Album Art -->
        <Border Grid.Column="0" CornerRadius="8" Width="90" Height="90" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Background>
                <ImageBrush x:Name="AlbumArtBrush" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
            <!-- Title -->
            <TextBlock x:Name="TitleText" Text="Waiting for music..."
                       Foreground="White" FontSize="16" FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"/>
            <!-- Artist -->
            <TextBlock x:Name="ArtistText" Text="---"
                       Foreground="#B0B0B0" FontSize="14" Margin="0,4,0,0"
                       TextTrimming="CharacterEllipsis"/>
            <!-- Status -->
            <TextBlock x:Name="StatusText" Text="Status: Unknown"
                       Foreground="#606060" FontSize="12" Margin="0,6,0,0"/>

            <!-- Option : couleur dynamique selon la pochette -->
            <CheckBox x:Name="DynamicColorCheckBox"
                      Content="&#x1F3A8; Couleur selon la pochette"
                      Foreground="#B0B0B0" FontSize="12" Margin="0,8,0,0"
                      Checked="DynamicColorCheckBox_Changed"
                      Unchecked="DynamicColorCheckBox_Changed"/>

            <!-- Option : visualiseur audio -->
            <CheckBox x:Name="AudioVisualizerCheckBox"
                      Content="&#x1F39A; Visualiseur audio (beta)"
                      Foreground="#B0B0B0" FontSize="12" Margin="0,4,0,0"
                      Checked="AudioVisualizerCheckBox_Changed"
                      Unchecked="AudioVisualizerCheckBox_Changed"/>
            <!-- Option : Discord Rich Presence -->
            <StackPanel Margin="0,8,0,0">
                <CheckBox x:Name="DiscordRpcCheckBox"
                          Content="&#x1F3AE; Discord Rich Presence"
                          Foreground="#B0B0B0" FontSize="12"
                          Checked="DiscordRpcCheckBox_Changed"
                          Unchecked="DiscordRpcCheckBox_Changed"/>
                
                <!-- Client ID Discord (visible seulement si activé) -->
                <StackPanel x:Name="DiscordSettingsPanel" Orientation="Horizontal" Margin="20,4,0,0" Visibility="Collapsed">
                    <TextBlock Text="Client ID:" Foreground="#606060" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="DiscordClientIdTextBox" Width="140" Height="20" FontSize="11"
                             Background="#28282A" Foreground="#B0B0B0" BorderBrush="#404040"
                             Padding="2" VerticalContentAlignment="Center"
                             LostFocus="DiscordClientIdTextBox_LostFocus"
                             ToolTip="L'ID de votre application Discord (Portail Développeur)"/>
                </StackPanel>
            </StackPanel>

            <!-- Error message if needed -->
            <TextBlock x:Name="ErrorText" Text=""
                       Foreground="Red" FontSize="10" Margin="0,4,0,0"/>
        </StackPanel>
    </Grid>
</Window>
